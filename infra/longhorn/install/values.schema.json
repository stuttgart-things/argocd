{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "longhorn install app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "defaultStorageClass": { "type": "boolean" },
    "defaultClassReplicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "volumeBindingMode": {
      "type": "string",
      "enum": ["Immediate", "WaitForFirstConsumer"]
    },
    "preUpgradeChecker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jobEnabled":          { "type": "boolean" },
        "upgradeVersionCheck": { "type": "boolean" }
      },
      "required": ["jobEnabled", "upgradeVersionCheck"]
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
