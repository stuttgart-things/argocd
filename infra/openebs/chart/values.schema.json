{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "openebs app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "preUpgradeHook": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "loki": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "alloy": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "volumeSnapshots": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "engines": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lvm": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "enabled": { "type": "boolean" } },
              "required": ["enabled"]
            },
            "zfs": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "enabled": { "type": "boolean" } },
              "required": ["enabled"]
            }
          },
          "required": ["lvm", "zfs"]
        },
        "replicated": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mayastor": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "enabled": { "type": "boolean" } },
              "required": ["enabled"]
            }
          },
          "required": ["mayastor"]
        }
      },
      "required": ["local", "replicated"]
    },
    "mayastorInitContainers": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
