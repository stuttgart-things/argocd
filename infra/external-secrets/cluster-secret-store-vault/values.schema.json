{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "external-secrets-cluster-secret-store-vault chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "server", "path", "auth"],
  "properties": {
    "name":    { "type": "string", "minLength": 1 },
    "server":  { "type": "string", "format": "uri" },
    "path":    { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1", "v2"] },
    "caProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "namespace", "key"],
      "properties": {
        "type":      { "type": "string", "enum": ["Secret", "ConfigMap"] },
        "name":      { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "key":       { "type": "string", "minLength": 1 }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kubernetes"],
      "properties": {
        "kubernetes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mountPath", "role", "serviceAccountRef"],
          "properties": {
            "mountPath": { "type": "string", "minLength": 1 },
            "role":      { "type": "string", "minLength": 1 },
            "serviceAccountRef": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "namespace"],
              "properties": {
                "name":      { "type": "string", "minLength": 1 },
                "namespace": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
