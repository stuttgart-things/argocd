{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "trust-manager install app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "trustNamespace": { "type": "string", "minLength": 1 },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
