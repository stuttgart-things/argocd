{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cert-manager-cluster-ca chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ca"
  ],
  "properties": {
    "ca": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "namespace",
        "secretName",
        "issuerRef"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        },
        "issuerRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "kind"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "enum": [
                "Issuer",
                "ClusterIssuer"
              ]
            }
          }
        }
      }
    },
    "wildcard": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        },
        "commonName": {
          "type": "string",
          "minLength": 1
        },
        "dnsNames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "duration": {
          "type": "string",
          "minLength": 1
        },
        "renewBefore": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "enabled"
      ],
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "name",
          "namespace",
          "secretName",
          "commonName",
          "dnsNames"
        ]
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
