{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cert-manager-vault-pki chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "vault"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "server",
        "path",
        "auth"
      ],
      "properties": {
        "server": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tokenSecretRef"
          ],
          "properties": {
            "tokenSecretRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "key"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "key": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
