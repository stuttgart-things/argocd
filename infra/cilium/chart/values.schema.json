{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cilium app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reference to this catalog repo, used by the optional lb / gateway Applications.",
      "properties": {
        "repoURL": { "type": "string", "format": "uri" },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "k8s": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceHost": { "type": "string" },
        "servicePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["serviceHost", "servicePort"]
    },
    "kubeProxyReplacement": { "type": "boolean" },
    "operatorReplicas": { "type": "integer", "minimum": 0 },
    "gatewayAPI": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "l2announcements": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "externalIPs": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "lb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "poolName": { "type": "string", "minLength": 1 },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "start": { "type": "string", "minLength": 1 },
              "stop":  { "type": "string", "minLength": 1 },
              "cidr":  { "type": "string", "minLength": 1 }
            }
          }
        },
        "l2Policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 },
            "externalIPs": { "type": "boolean" },
            "loadBalancerIPs": { "type": "boolean" }
          },
          "required": ["name", "namespace", "externalIPs", "loadBalancerIPs"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["poolName", "blocks", "l2Policy"] }
    },
    "gateway": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "gatewayClassName": { "type": "string", "minLength": 1 },
        "hostname": { "type": "string", "minLength": 1 },
        "tlsSecretName": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["name", "namespace", "gatewayClassName", "hostname", "tlsSecretName"] }
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
