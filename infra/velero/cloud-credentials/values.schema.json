{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "velero-cloud-credentials chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "namespace", "secretStoreRef", "secretPath", "properties"],
  "properties": {
    "name":            { "type": "string", "minLength": 1 },
    "namespace":       { "type": "string", "minLength": 1 },
    "refreshInterval": { "type": "string", "minLength": 1 },
    "secretStoreRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"] }
      },
      "required": ["name", "kind"]
    },
    "secretPath": { "type": "string", "minLength": 1 },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessKey": { "type": "string", "minLength": 1 },
        "secretKey": { "type": "string", "minLength": 1 }
      },
      "required": ["accessKey", "secretKey"]
    }
  }
}
