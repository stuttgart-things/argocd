{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "zitadel-secrets sub-chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "namespace",
    "secretName",
    "values"
  ],
  "properties": {
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "secretName": {
      "type": "string",
      "minLength": 1
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "masterkey": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
