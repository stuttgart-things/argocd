{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "zitadel-external-secrets sub-chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "namespace",
    "secretName",
    "store",
    "secretPath",
    "keys"
  ],
  "properties": {
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "secretName": {
      "type": "string",
      "minLength": 1
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["ClusterSecretStore", "SecretStore"]
        }
      },
      "required": ["name", "kind"]
    },
    "secretPath": {
      "type": "string",
      "minLength": 1
    },
    "refreshInterval": {
      "type": "string",
      "minLength": 1
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
