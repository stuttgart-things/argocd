{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claim-machinery-api app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "kustomize", "image", "auth", "trustBundle"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repoURL": { "type": "string", "format": "uri" },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "kustomize": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repoURL":        { "type": "string", "minLength": 1 },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag":        { "type": "string", "minLength": 1 }
      },
      "required": ["repository", "tag"]
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "templateProfilePath": { "type": "string" },
        "homerun": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "url":     { "type": "string" }
          },
          "required": ["enabled"]
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "secretName": { "type": "string", "minLength": 1 },
        "secretKey":  { "type": "string", "minLength": 1 }
      },
      "required": ["secretName", "secretKey"]
    },
    "trustBundle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "configMapName": { "type": "string", "minLength": 1 },
        "key":           { "type": "string", "minLength": 1 },
        "sslCertDir":    { "type": "string", "minLength": 1 }
      },
      "required": ["configMapName", "key", "sslCertDir"]
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":  { "type": "boolean" },
        "hostname": { "type": "string", "minLength": 1 },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name":      { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["hostname", "gateway"] }
    },
    "authSecret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":          { "type": "boolean" },
        "homerunAuthToken": { "type": "string" }
      },
      "required": ["enabled"]
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
