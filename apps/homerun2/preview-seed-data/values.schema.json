{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "homerun2-preview-seed-data chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "namespacePrefix", "image", "omniPitcherService", "omniPitcherPort", "authTokenSecretName", "authTokenSecretKey", "healthCheck", "jobTtlSecondsAfterFinished", "events"],
  "properties": {
    "name":                       { "type": "string", "minLength": 1 },
    "namespacePrefix":            { "type": "string", "minLength": 1 },
    "image":                      { "type": "string", "minLength": 1 },
    "omniPitcherService":         { "type": "string", "minLength": 1 },
    "omniPitcherPort":            { "type": "integer", "minimum": 1, "maximum": 65535 },
    "authTokenSecretName":        { "type": "string", "minLength": 1 },
    "authTokenSecretKey":         { "type": "string", "minLength": 1 },
    "jobTtlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
    "healthCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempts", "intervalSeconds"],
      "properties": {
        "attempts":        { "type": "integer", "minimum": 1 },
        "intervalSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "description": "Free-form JSON body posted to /pitch. Required keys depend on what the omni-pitcher build accepts; typically: title, message, severity, author, system, tags."
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
