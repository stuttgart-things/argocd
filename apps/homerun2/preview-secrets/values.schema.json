{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "homerun2-preview-secrets chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "namespacePrefix", "clusterSecretStoreName", "refreshInterval", "vaultSecretName", "components"],
  "properties": {
    "name":                   { "type": "string", "minLength": 1 },
    "namespacePrefix":        { "type": "string", "minLength": 1 },
    "clusterSecretStoreName": { "type": "string", "minLength": 1 },
    "refreshInterval":        { "type": "string", "minLength": 1 },
    "vaultSecretName":        { "type": "string", "minLength": 1 },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "secretName", "dataKey", "vaultProperty"],
        "properties": {
          "name":          { "type": "string", "minLength": 1 },
          "secretName":    { "type": "string", "minLength": 1 },
          "dataKey":       { "type": "string", "minLength": 1 },
          "vaultProperty": { "type": "string", "minLength": 1 }
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
