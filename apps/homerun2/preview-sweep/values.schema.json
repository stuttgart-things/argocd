{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "homerun2-preview-sweep chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "namespacePrefix", "maxAge", "schedule"],
  "properties": {
    "name":            { "type": "string", "minLength": 1 },
    "namespacePrefix": { "type": "string", "minLength": 1 },
    "maxAge":          { "type": "string", "minLength": 1, "description": "Go duration string (e.g. 1h, 24h, 168h)." },
    "schedule":        { "type": "string", "minLength": 1, "description": "Cron expression for the cleanup controller." },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
