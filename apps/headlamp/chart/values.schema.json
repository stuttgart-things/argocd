{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "headlamp app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reference to this catalog repo, used by the optional rbac Application.",
      "properties": {
        "repoURL": { "type": "string", "format": "uri" },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "project": {
      "type": "string",
      "minLength": 1,
      "description": "ArgoCD AppProject for the rendered Applications."
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server": { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream Headlamp chart version."
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "hostname": { "type": "string", "minLength": 1 },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["hostname", "gateway"] }
    },
    "plugins": {
      "type": "array",
      "description": "Plugins loaded by Headlamp's pluginsManager. Empty disables pluginsManager.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "format": "uri" }
        },
        "required": ["name", "source"]
      }
    },
    "extraValues": {
      "type": "object",
      "description": "Deep-merged on top of the computed valuesObject passed to the upstream chart.",
      "additionalProperties": true
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "syncPolicy": {
      "type": "object",
      "description": "ArgoCD sync policy applied to both rendered Applications.",
      "additionalProperties": true
    }
  }
}
