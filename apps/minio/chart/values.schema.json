{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "minio app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion", "image", "console", "api"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repoURL": { "type": "string", "format": "uri" },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server": { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 }
      },
      "required": ["registry", "repository", "tag"]
    },
    "storageClass": { "type": "string", "minLength": 1 },
    "storageSize": { "type": "string", "minLength": 1, "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei)?$" },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rootUser":       { "type": "string" },
        "rootPassword":   { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": { "type": "object", "additionalProperties": true },
        "limits":   { "type": "object", "additionalProperties": true }
      }
    },
    "console": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostname":  { "type": "string", "minLength": 1 },
        "tlsSecret": { "type": "string", "minLength": 1 }
      },
      "required": ["hostname", "tlsSecret"]
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostname":  { "type": "string", "minLength": 1 },
        "tlsSecret": { "type": "string", "minLength": 1 }
      },
      "required": ["hostname", "tlsSecret"]
    },
    "certs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
          },
          "required": ["name", "kind"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["issuer"] }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name":      { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["gateway"] }
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
