{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "minio-certs sub-chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace", "issuer", "certificates"],
  "properties": {
    "namespace": { "type": "string", "minLength": 1 },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
      },
      "required": ["name", "kind"]
    },
    "certificates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name":       { "type": "string", "minLength": 1 },
          "commonName": { "type": "string", "minLength": 1 },
          "dnsNames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "secretName": { "type": "string", "minLength": 1 }
        },
        "required": ["name", "commonName", "dnsNames", "secretName"]
      }
    }
  }
}
