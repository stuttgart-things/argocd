{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "harbor app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion", "hostname", "domain"],
  "properties": {
    "applicationName": { "type": "string", "minLength": 1 },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repoURL": { "type": "string", "format": "uri" },
        "targetRevision": { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision"]
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion":  { "type": "string", "minLength": 1 },
    "hostname":      { "type": "string", "minLength": 1 },
    "domain":        { "type": "string", "minLength": 1 },
    "adminPassword": { "type": "string" },
    "storageClass":  { "type": "string", "minLength": 1 },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":        { "type": "boolean" },
        "registrySize":   { "type": "string", "minLength": 1, "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei)?$" },
        "trivySize":      { "type": "string", "minLength": 1, "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei)?$" },
        "jobserviceSize": { "type": "string", "minLength": 1, "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei)?$" }
      },
      "required": ["enabled"]
    },
    "exposureType": {
      "type": "string",
      "enum": ["ingress", "clusterIP", "nodePort", "loadBalancer"]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":   { "type": "boolean" },
        "className": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled"]
    },
    "certs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
          },
          "required": ["name", "kind"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["issuer"] }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name":      { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace"]
        }
      },
      "required": ["enabled"],
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["gateway"] }
    },
    "projectProxy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":      { "type": "boolean" },
        "chartVersion": { "type": "string", "minLength": 1 },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":   { "type": "boolean" },
            "className": { "type": "string", "minLength": 1 }
          },
          "required": ["enabled"]
        }
      },
      "required": ["enabled"]
    },
    "extraValues": { "type": "object", "additionalProperties": true },
    "syncPolicy":  { "type": "object", "additionalProperties": true }
  }
}
