{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "backstage-secrets sub-chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "namespace",
    "secretName",
    "values"
  ],
  "properties": {
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "secretName": {
      "type": "string",
      "minLength": 1
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appTitle": {
          "type": "string"
        },
        "organizationName": {
          "type": "string"
        },
        "appBaseURL": {
          "type": "string"
        },
        "backendBaseURL": {
          "type": "string"
        },
        "corsOrigin": {
          "type": "string"
        },
        "authEnvironment": {
          "type": "string"
        },
        "claimMachineryAPIURL": {
          "type": "string"
        },
        "claimMachineryRegistryURL": {
          "type": "string"
        },
        "github": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "token": {
              "type": "string"
            },
            "clientId": {
              "type": "string"
            },
            "clientSecret": {
              "type": "string"
            }
          }
        },
        "backendSecret": {
          "type": "string"
        },
        "externalAccessToken": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
