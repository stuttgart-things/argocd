{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "machinery-rbac chart",
  "type": "object",
  "_comment": "additionalProperties left open so the catalog verifier (call-argocd-verify-catalog) can inject its common probe values like `destination` without tripping the schema.",
  "additionalProperties": true,
  "required": ["name", "serviceAccount", "rules"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "ClusterRole + ClusterRoleBinding name."
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "namespace"],
      "properties": {
        "name":      { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 }
      }
    },
    "rules": {
      "type": "array",
      "description": "ClusterRole rules. apiGroups + resources required; verbs default to get/list/watch.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["apiGroups", "resources"],
        "properties": {
          "apiGroups": { "type": "array", "items": { "type": "string" } },
          "resources": { "type": "array", "items": { "type": "string" } },
          "verbs":     { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
