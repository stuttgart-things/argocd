{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tekton-config chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "profile",
    "targetNamespace",
    "pipeline",
    "pruner"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "lite",
        "basic",
        "all"
      ]
    },
    "targetNamespace": {
      "type": "string",
      "minLength": 1
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enableApiFields": {
          "type": "string",
          "enum": [
            "alpha",
            "beta",
            "stable"
          ]
        },
        "disableInlineSpec": {
          "type": "string"
        }
      },
      "required": [
        "enableApiFields",
        "disableInlineSpec"
      ]
    },
    "pruner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disabled",
        "resources",
        "keep",
        "schedule"
      ],
      "properties": {
        "disabled": {
          "type": "boolean"
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "taskrun",
              "pipelinerun"
            ]
          }
        },
        "keep": {
          "type": "integer",
          "minimum": 1
        },
        "schedule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extraSpec": {
      "type": "object",
      "additionalProperties": true
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
