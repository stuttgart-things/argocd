{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tekton operator app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "source"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repoURL":        { "type": "string", "minLength": 1 },
        "targetRevision": { "type": "string", "minLength": 1 },
        "path":           { "type": "string", "minLength": 1 }
      },
      "required": ["repoURL", "targetRevision", "path"]
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
