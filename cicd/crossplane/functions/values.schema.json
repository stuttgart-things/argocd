{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "crossplane-functions chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["functions"],
  "properties": {
    "functions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "package"],
        "properties": {
          "name":       { "type": "string", "minLength": 1 },
          "package":    { "type": "string", "minLength": 1 },
          "apiVersion": {
            "type": "string",
            "enum": ["pkg.crossplane.io/v1", "pkg.crossplane.io/v1beta1"]
          }
        }
      }
    }
  }
}
