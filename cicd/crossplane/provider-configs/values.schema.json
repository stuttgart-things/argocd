{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "crossplane-provider-configs chart",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "configs"
  ],
  "properties": {
    "configs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "apiVersion",
          "spec"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "namespace": {
            "type": "string",
            "minLength": 1
          },
          "apiVersion": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "spec": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inert pass-through. Present so verify-catalog's probe values do not fail strict additionalProperties:false validation; the chart itself does not consume this field."
    }
  }
}
