{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "crossplane install app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "name":      { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["namespace"],
      "anyOf": [
        { "required": ["server"] },
        { "required": ["name"] }
      ]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "args": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "providerPackages": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
