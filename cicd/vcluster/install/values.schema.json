{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vcluster app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion", "k8sVersion"],
  "properties": {
    "applicationName": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "k8sVersion":   { "type": "string", "minLength": 1 },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": { "type": "object", "additionalProperties": true },
        "limits":   { "type": "object", "additionalProperties": true }
      }
    },
    "replicas": { "type": "integer", "minimum": 1 },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":      { "type": "boolean" },
        "storageClass": { "type": "string" },
        "size":         { "type": "string", "minLength": 1, "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei)?$" }
      },
      "required": ["enabled"]
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "toHost": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "services":               { "type": "boolean" },
            "endpoints":              { "type": "boolean" },
            "persistentVolumeClaims": { "type": "boolean" }
          }
        },
        "fromHost": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "events":         { "type": "boolean" },
            "storageClasses": { "type": "boolean" },
            "nodes":          { "type": "boolean" },
            "ingressClasses": { "type": "boolean" }
          }
        }
      }
    },
    "extraValues": { "type": "object", "additionalProperties": true },
    "syncPolicy":  { "type": "object", "additionalProperties": true }
  }
}
