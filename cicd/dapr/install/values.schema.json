{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dapr install app-of-apps chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "destination", "chartVersion"],
  "properties": {
    "applicationName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional explicit name for the rendered ArgoCD Application. Defaults to a per-cluster derived name to avoid collisions when deployed to multiple clusters."
    },
    "project": { "type": "string", "minLength": 1 },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server":    { "type": "string", "format": "uri" },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["server", "namespace"]
    },
    "chartVersion": { "type": "string", "minLength": 1 },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ha": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "required": ["enabled"]
        },
        "logAsJson": { "type": "boolean" }
      },
      "required": ["ha", "logAsJson"]
    },
    "logLevel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator":        { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "placement":       { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "sidecarInjector": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "scheduler":       { "type": "string", "enum": ["debug", "info", "warn", "error"] }
      },
      "required": ["operator", "placement", "sidecarInjector", "scheduler"]
    },
    "extraValues": {
      "type": "object",
      "additionalProperties": true
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
