{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "kargo-certs chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["certificates"],
  "properties": {
    "certificates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "namespace", "commonName", "dnsNames", "secretName", "issuerRef"],
        "properties": {
          "name":       { "type": "string", "minLength": 1 },
          "namespace":  { "type": "string", "minLength": 1 },
          "commonName": { "type": "string", "minLength": 1 },
          "dnsNames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "secretName": { "type": "string", "minLength": 1 },
          "issuerRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
            }
          }
        }
      }
    }
  }
}
